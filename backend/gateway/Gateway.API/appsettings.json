{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Yarp": "Information",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/gateway-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "Jwt": {
    "SecretKey": "NexosABC_SuperSecretKey_2024_MustBe32CharsOrMore!",
    "Issuer": "NexosABC.API",
    "Audience": "NexosABC.Client"
  },
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "RealIpHeader": "X-Forwarded-For",
    "ClientIdHeader": "X-ClientId",
    "HttpStatusCode": 429,
    "QuotaExceededResponse": {
      "Content": "{\"error\": \"Demasiadas solicitudes. Por favor, intente más tarde.\", \"code\": \"RATE_LIMIT_EXCEEDED\"}",
      "ContentType": "application/json",
      "StatusCode": 429
    },
    "GeneralRules": [
      {
        "Endpoint": "*",
        "Period": "1m",
        "Limit": 100
      },
      {
        "Endpoint": "*",
        "Period": "1h",
        "Limit": 1000
      },
      {
        "Endpoint": "post:/api/auth/login",
        "Period": "1m",
        "Limit": 10
      },
      {
        "Endpoint": "post:/api/auth/register",
        "Period": "1h",
        "Limit": 5
      }
    ]
  },
  "IpRateLimitPolicies": {
    "IpRules": []
  },
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "usuarios-cluster",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/auth/{**catch-all}" }
        ]
      },
      "usuarios-route": {
        "ClusterId": "usuarios-cluster",
        "Match": {
          "Path": "/api/usuarios/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/usuarios/{**catch-all}" }
        ],
        "AuthorizationPolicy": "authenticated"
      },
      "users-route": {
        "ClusterId": "usuarios-cluster",
        "Match": {
          "Path": "/api/users/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/usuarios/{**catch-all}" }
        ],
        "AuthorizationPolicy": "authenticated"
      },
      "pedidos-route": {
        "ClusterId": "pedidos-cluster",
        "Match": {
          "Path": "/api/pedidos/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/pedidos/{**catch-all}" }
        ],
        "AuthorizationPolicy": "authenticated"
      },
      "orders-route": {
        "ClusterId": "pedidos-cluster",
        "Match": {
          "Path": "/api/orders/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/pedidos/{**catch-all}" }
        ],
        "AuthorizationPolicy": "authenticated"
      },
      "pagos-route": {
        "ClusterId": "pagos-cluster",
        "Match": {
          "Path": "/api/pagos/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/pagos/{**catch-all}" }
        ],
        "AuthorizationPolicy": "authenticated"
      },
      "payments-route": {
        "ClusterId": "pagos-cluster",
        "Match": {
          "Path": "/api/payments/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/pagos/{**catch-all}" }
        ],
        "AuthorizationPolicy": "authenticated"
      },
      "health-usuarios": {
        "ClusterId": "usuarios-cluster",
        "Match": {
          "Path": "/health/usuarios"
        },
        "Transforms": [
          { "PathPattern": "/health" }
        ]
      },
      "health-pedidos": {
        "ClusterId": "pedidos-cluster",
        "Match": {
          "Path": "/health/pedidos"
        },
        "Transforms": [
          { "PathPattern": "/health" }
        ]
      },
      "health-pagos": {
        "ClusterId": "pagos-cluster",
        "Match": {
          "Path": "/health/pagos"
        },
        "Transforms": [
          { "PathPattern": "/health" }
        ]
      }
    },
    "Clusters": {
      "usuarios-cluster": {
        "Destinations": {
          "usuarios-api": {
            "Address": "http://localhost:5001"
          }
        },
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:30",
            "Timeout": "00:00:10",
            "Policy": "ConsecutiveFailures",
            "Path": "/health"
          }
        },
        "HttpClient": {
          "RequestHeaderEncoding": "UTF-8"
        }
      },
      "pedidos-cluster": {
        "Destinations": {
          "pedidos-api": {
            "Address": "http://localhost:5002"
          }
        },
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:30",
            "Timeout": "00:00:10",
            "Policy": "ConsecutiveFailures",
            "Path": "/health"
          }
        },
        "HttpClient": {
          "RequestHeaderEncoding": "UTF-8"
        }
      },
      "pagos-cluster": {
        "Destinations": {
          "pagos-api": {
            "Address": "http://localhost:5003"
          }
        },
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:30",
            "Timeout": "00:00:10",
            "Policy": "ConsecutiveFailures",
            "Path": "/health"
          }
        },
        "HttpClient": {
          "RequestHeaderEncoding": "UTF-8"
        }
      }
    }
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:4200",
      "http://localhost:4201",
      "http://localhost"
    ]
  },
  "AllowedHosts": "*"
}
