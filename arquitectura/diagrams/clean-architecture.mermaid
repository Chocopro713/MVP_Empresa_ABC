graph TB
    subgraph Gateway["🚪 API Gateway (YARP)"]
        GW[Gateway API<br/>───────────<br/>Reverse Proxy<br/>Request Routing<br/>Port: 5050]
    end

    subgraph Usuarios["📦 Usuarios Microservice"]
        direction TB
        UA[API Layer<br/>Controllers + ApiResponse<br/>JWT Authentication]
        UApp[Application Layer<br/>AuthService + UserService<br/>Password Hashing]
        UD[Domain Layer<br/>Entities & Interfaces]
        UI[Infrastructure Layer<br/>MongoDB Repository<br/>JWT Token Generation]
        
        UA --> UApp
        UApp --> UD
        UI --> UD
    end
    
    subgraph Pedidos["📦 Pedidos Microservice"]
        direction TB
        PA[API Layer<br/>Controllers + ApiResponse<br/>Search by Query]
        PApp[Application Layer<br/>Services & DTOs]
        PD[Domain Layer<br/>Entities & Interfaces]
        PI[Infrastructure Layer<br/>MongoDB Repository]
        
        PA --> PApp
        PApp --> PD
        PI --> PD
    end
    
    subgraph Pagos["📦 Pagos Microservice"]
        direction TB
        PgA[API Layer<br/>Controllers + ApiResponse<br/>Payment Processing]
        PgApp[Application Layer<br/>Services & DTOs]
        PgD[Domain Layer<br/>Entities & Interfaces]
        PgI[Infrastructure Layer<br/>MongoDB Repository]
        
        PgA --> PgApp
        PgApp --> PgD
        PgI --> PgD
    end

    GW --> UA
    GW --> PA
    GW --> PgA
    
    style GW fill:#673AB7,color:#fff
    style UA fill:#2196F3,color:#fff
    style UApp fill:#4CAF50,color:#fff
    style UD fill:#FF9800,color:#fff
    style UI fill:#9C27B0,color:#fff
    
    style PA fill:#2196F3,color:#fff
    style PApp fill:#4CAF50,color:#fff
    style PD fill:#FF9800,color:#fff
    style PI fill:#9C27B0,color:#fff
    
    style PgA fill:#2196F3,color:#fff
    style PgApp fill:#4CAF50,color:#fff
    style PgD fill:#FF9800,color:#fff
    style PgI fill:#9C27B0,color:#fff
